# Copy to .env (which is gitignored) and adjust as needed.
# docker-compose reads these; so does the API/worker via pydantic-settings.

# --- Postgres ---
POSTGRES_USER=awp
POSTGRES_PASSWORD=awp
POSTGRES_DB=awp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full URL the app uses. Async driver (asyncpg) for FastAPI.
DATABASE_URL=postgresql+asyncpg://awp:awp@localhost:5432/awp

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=awp-api

# --- LLM (provider-agnostic, OpenAI-compatible) ---
# LLM_PROVIDER: mock | openai | groq | openrouter | ollama | together
# Leave as "mock" to run at $0. Examples for real providers below.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=mock-gpt
# Comma-separated list shown in the run form's model picker:
LLM_MODELS=mock-gpt
#
# Examples (uncomment & set a key):
#   OpenAI:     LLM_PROVIDER=openai     LLM_MODEL=gpt-4o-mini   LLM_MODELS=gpt-4o-mini,gpt-4o
#   Groq:       LLM_PROVIDER=groq       LLM_MODEL=llama-3.1-8b-instant
#   OpenRouter: LLM_PROVIDER=openrouter LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
#   Ollama:     LLM_PROVIDER=ollama     LLM_MODEL=llama3.2   (no key needed; run `ollama serve`)
